# Server Configuration
PORT=3000
SESSION_SECRET=your_session_secret_here

# Persistence (Auto-created if omitted)
# DATABASE_URL=./data/whatsapp-center.sqlite

# ==========================================
# GESTION DES CLES (MANAGED VIA DASHBOARD)
# ==========================================
# The following keys are automatically migrated to 
# the database on first boot. After migration, 
# you should manage them via the Settings UI.

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Twilio WhatsApp Integration
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_DEFAULT_MESSAGING_SERVICE_SID=your_messaging_service_sid_here

# Google OAuth (Public Client ID)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
